title: Test
subtitle: Just a test choice
is-special: true
new-page: true

= Test

AI text improver test:

- @ai_test: Test ai

@ai_test
title: Test ai

Me: Test ai

{!<textarea id="ai-textarea" class="textarea" data-quality="ai_text" placeholder="Write your custom answer." oninput="window.dendryUI && window.dendryUI.dendryEngine && (window.dendryUI.dendryEngine.state.qualities[this.dataset.quality] = this.value);">!}[+ ai_text +]{!</textarea>!}


- @ai_answer: Save

@ai_answer
title: Get answer
on-arrival: {! setTimeout(async function () {
  var statusElement = document.getElementById("ai-status");
  var outputElement = document.getElementById("ai-output");
  var reviewElement = document.getElementById("ai-review");
  var sourceText = Q.ai_text || "";
  if (!sourceText) {
    statusElement.textContent = "Please enter some text first.";
    return;
  }
  statusElement.textContent = "Improving text...";
  outputElement.textContent = sourceText;
  reviewElement.textContent = "Reviewing text...";
  try {
    var response = await fetch("/api/improve-text", {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify({ text: sourceText })
    });
    var responseBody = await response.json();
    if (!response.ok) throw new Error(responseBody.error || "AI did not respond.");
    Q.ai_text = responseBody.improvedText || sourceText;
    Q.ai_review = responseBody.review || "";
    outputElement.textContent = Q.ai_text;
    reviewElement.textContent = Q.ai_review ? "Review: " + Q.ai_review : "";
    statusElement.textContent = "Text improved.";
  } catch (error) {
    statusElement.textContent = error.message || "Unable to improve the text right now.";
    reviewElement.textContent = "Unable to review your text right now.";
  }
}, 0); !}

RoboDisplay: {!<div id="ai-status" aria-live="polite"></div>!}

Paper: {!<div id="ai-output" style="white-space: pre-wrap;">!}[+ ai_text +]{!</div>!}

RoboDisplay: {!<div id="ai-review" aria-live="polite">!}[+ ai_review +]{!</div>!}


