AI text improver test:

- @ai_test: Test ai

@ai_test
title: Test ai

Me: Test ai

{!<textarea id="ai-textarea" class="textarea" data-quality="holtext" placeholder="Write your custom answer." oninput="window.dendryUI && window.dendryUI.dendryEngine && (window.dendryUI.dendryEngine.state.qualities[this.dataset.quality] = this.value);">!}[+ holtext +]{!</textarea>!}


- @ai_answer

@ai_answer
title: Improve
on-arrival: {! setTimeout(async function () {
  function parseAiResponse(responseText) {
    if (typeof responseText !== "string") return null;
    var trimmed = responseText.trim();
    if (!trimmed) return null;
    try {
      return JSON.parse(trimmed);
    } catch (error) {
      var jsonMatch = trimmed.match(/```(?:json)?\s*([\s\S]*?)\s*```/i);
      if (!jsonMatch) return null;
      try {
        return JSON.parse(jsonMatch[1]);
      } catch (nestedError) {
        return null;
      }
    }
  }

  var statusElement = document.getElementById("ai-status");
  var outputElement = document.getElementById("ai-output");
  var reviewElement = document.getElementById("ai-review");
  var sourceText = Q.holtext || "";
  if (!sourceText) {
    statusElement.textContent = "Please enter some text first.";
    return;
  }
  statusElement.textContent = "Improving text...";
  outputElement.textContent = sourceText;
  reviewElement.textContent = "Reviewing text...";
  try {
    var systemPrompt = 'Improve the text for clarity and flow without changing its meaning or tone. Preserve the input’s paragraphing and line breaks (do not merge lines). Also provide a short review of the changes. Return valid JSON only in this shape: {"improvedText":"...","review":"..."}. Keep `review` under 25 words.';
    var response = await fetch("/ai/improve-text", {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify({
        messages: [
          { role: "system", content: systemPrompt },
          { role: "user", content: sourceText }
        ],
        temperature: 0.2,
        max_tokens: 700
      })
    });
    var responseBody = await response.json();
    if (!response.ok) throw new Error(responseBody.error || "AI did not respond.");
    var parsed = parseAiResponse(responseBody.response);
    var improvedText = parsed && typeof parsed.improvedText === "string" ? parsed.improvedText.trim() : "";
    var review = parsed && typeof parsed.review === "string" ? parsed.review.trim() : "";
    if (!improvedText) throw new Error("The AI did not return any improved text.");
    Q.holtext = improvedText;
    Q.ai_review = review;
    outputElement.textContent = Q.holtext;
    reviewElement.textContent = Q.ai_review ? "Review: " + Q.ai_review : "";
    statusElement.textContent = "Text improved.";
  } catch (error) {
    statusElement.textContent = error.message || "Unable to improve the text right now.";
    reviewElement.textContent = "Unable to review your text right now.";
  }
}, 0); !}

RoboDisplay: {!<div id="ai-status" aria-live="polite"></div>!}

Paper: {!<div id="ai-output" style="white-space: pre-wrap;">!}[+ holtext +]{!</div>!}

RoboDisplay: {!<div id="ai-review" aria-live="polite">!}[+ ai_review +]{!</div>!}


